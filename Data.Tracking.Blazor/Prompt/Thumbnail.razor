@if(!string.IsNullOrEmpty(Url))
{
    <img src="@Url" role="button" class="card-img-top bg-light img-zoom @(Class)" style="width: 80px; height:45px;" @onclick="@ShowViewer" alt="@Title" />
  
    <UserPrompt @ref="viewer" Title="@Title">
        <ChildContent>
            @if (!string.IsNullOrEmpty(Description))
            {
                <p>@Description</p>
            }
            <img src="@Url" class="card-img-top img-zoom bg-light" style="width: 100%" alt="@Title" />
        </ChildContent>
        <Footer></Footer>        
    </UserPrompt>
}




