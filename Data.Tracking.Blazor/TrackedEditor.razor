@using Oarw.Data.Tracking
@using System.Net.Http
@using Microsoft.JSInterop
@using Oarw.Data.Tracking.Blazor.Prompt
@typeparam TItem

@inject HttpClient Http
@inject IJSRuntime JsRuntime;

<EditPrompt @ref="userPrompt" Title="@(Create ? "New " + Title : "Edit " + Title)" Size="@Size" afterCancel="CancelEdit">
    @if(ActiveBinding?.TryGetEditTemplate(EditItem, out RenderFragment template) == true)
    {
        @template
    }
    else if (EditItem != null)
    {
        @EditModal(EditItem)
    }
</EditPrompt>

@if(Bindings != null)
{
    <TrackedUpdate @ref="updateDefinitions" AutoSaveInterval="@AutoSaveInterval">
        @Bindings
    </TrackedUpdate>
}

<CascadingValue Value="this">
    @ChildContent
</CascadingValue>
